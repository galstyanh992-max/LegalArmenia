# =============================================================================
# AI LEGAL ARMENIA — local environment (.env)
# WARNING: contains REAL secrets. This file is gitignored (see .gitignore: .env*).
# Never commit it. Never expose SERVICE_ROLE / DATABASE_URL to the browser.
# Browser may use ONLY VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY (RLS-protected).
# =============================================================================

# =============================================================================
# OpenRouter (LLM gateway) — PRIMARY
# Provider auto-selects: AI_PROVIDER override > OPENROUTER_API_KEY > OPENAI_API_KEY > Gemini
# ▶ Set OPENROUTER_API_KEY to activate OpenRouter for ALL edge functions.
# ▶ Must ALSO be added to Supabase Dashboard → Edge Functions → Secrets.
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# --- Per-function model overrides (optional — model-registry.ts provides defaults) ---
# Uncomment and set to override a specific function's primary model at deploy time.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=
OPENROUTER_FALLBACK_ENABLED=
# Format: OPENROUTER_MODEL_<FUNCTION_NAME_UPPERCASED_UNDERSCORED>=<openrouter-model-slug>
#
# OPENROUTER_MODEL_AI_ANALYZE=
# OPENROUTER_MODEL_MULTI_AGENT_ANALYZE=
# OPENROUTER_MODEL_MULTI_AGENT_ANALYZE_SYNTHESIS=
# OPENROUTER_MODEL_GENERATE_DOCUMENT=
# OPENROUTER_MODEL_MAP_REDUCE_SUMMARIZER=
# OPENROUTER_MODEL_TELEGRAM_WEBHOOK=

# --- OpenAI (direct) — SECONDARY. Used if OPENROUTER_API_KEY is empty. ---
# For EDGE FUNCTIONS these must ALSO be set in Supabase Dashboard → Edge Functions → Secrets.
OPENAI_API_KEY=
OPENAI_MODEL=
# OPENAI_BASE_URL=
# AI_PROVIDER=
VERCEL_TOKEN=

# GITHUB_PERSONAL_ACCESS_TOKEN=
# --- App ---
APP_URL=

# =============================================================================
# Supabase project: avmgtsonawtzebvazgcr  (NEW / current)
# =============================================================================

# Server-side (edge functions / ingestion / migrations).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SERVER ONLY — bypasses RLS. Never ship to browser.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
# Postgres via SESSION POOLER (IPv4-friendly, verified working). Region ap-northeast-1.
# Port 5432 = session (migrations/psql); 6543 = transaction.
DATABASE_URL=
# Direct (IPv6-only; does NOT resolve from IPv4). Reference only:
# DATABASE_URL_DIRECT=

# --- Frontend (Vite). MUST be VITE_-prefixed to reach the browser client. ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Edge function secrets — set these in Supabase Dashboard → Edge Functions → Secrets.
# (SUPABASE_URL / ANON / SERVICE_ROLE are auto-injected into edge functions by the platform.)
# Listed here only as a checklist; fill real values in the dashboard.
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Embeddings (Armenian open-source model, self-hosted via sentence-transformers) ---
# Active provider. base: intfloat/multilingual-e5-large, 1024-dim, cosine.
EMBEDDING_MODEL=
EMBEDDING_DB_MODEL=
EMBEDDING_DIM=
EMBEDDING_BATCH=
# EMBEDDING_DEVICE=
# Query-embedding HTTP service (scripts/embedding_server.py) used by the search layer:
EMBEDDING_ENDPOINT=
# EMBEDDING_API_KEY=

# --- Cohere (embeddings) — legacy/unused, kept for the Deno worker fallback only ---
COHERE_API_KEY=

VITE_SUPABASE_PUBLISHABLE_KEY=